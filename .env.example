# Скопируй этот файл в .env и заполни своими значениями
# cp .env.example .env

# ── Обязательные ────────────────────────────────────────────
BOT_TOKEN=токен_от_BotFather

# Ключи OpenRouter (можно несколько через запятую)
OPENROUTER_API_KEY=sk-or-v1-ключ1,sk-or-v1-ключ2

# Аккаунты для входа в админ-панель (JSON)
ADMIN_ACCOUNTS={"sergey_defa":"Ser123asd","Blackjack":"Sergey"}
ADMIN_PASSWORD=твой_пароль

# ── Почта (опционально, для восстановления пароля) ──────────
SMTP_USER=почта@gmail.com
SMTP_PASSWORD=пароль_приложения_gmail

# ── Почта для приёма платежей (опционально) ─────────────────
PAYMENT_EMAIL_USER=почта@gmail.com
PAYMENT_EMAIL_PASS=пароль_приложения_gmail
